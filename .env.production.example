# ============================================
# NoteFlow 生产环境变量模板
# 复制到 Vercel Dashboard → Settings → Environment Variables
# ============================================

# ── 必填 ──────────────────────────────────────

# Railway PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:port/railway
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.railway.app:5432/railway"

# NextAuth 密钥（生成: openssl rand -base64 32）
AUTH_SECRET="your-production-secret-here"
NEXTAUTH_SECRET="your-production-secret-here"

# Vercel 部署后的公开 URL（不要末尾斜杠）
NEXTAUTH_URL="https://noteflow.vercel.app"

# ── 推荐 ──────────────────────────────────────

# xAI Grok API — 完整 AI 功能
XAI_API_KEY="xai-xxxxxxxx"

# ── 可选 ──────────────────────────────────────

# Google OAuth（需在 Google Cloud Console 配置回调 URL）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# 回调 URL: https://noteflow.vercel.app/api/auth/callback/google

# Node 环境（Vercel 自动设置，无需手动配置）
# NODE_ENV=production