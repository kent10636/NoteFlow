# ============================================
# NoteFlow 生产环境变量模板（仅占位符，无真实密钥）
# 配置位置：Vercel Dashboard → Settings → Environment Variables
# ============================================

# ── 必填 ──────────────────────────────────────

# 数据库连接（Prisma Postgres / Railway / Neon 等）
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth 密钥（生成: openssl rand -base64 32）
AUTH_SECRET="your-production-secret-here"
NEXTAUTH_SECRET="your-production-secret-here"

# 部署后的公开 URL（不要末尾斜杠）
NEXTAUTH_URL="https://your-app.vercel.app"

# ── 推荐 ──────────────────────────────────────

# xAI Grok API — 完整 AI 功能
XAI_API_KEY="xai-your-key-here"

# ── 可选 ──────────────────────────────────────

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# 回调 URL: https://your-app.vercel.app/api/auth/callback/google